```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Build artifacts
dist/
build/
target/

# Dependencies cache
.mypy_cache/
.pytest_cache/
.node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db
```